# ========== 后端服务配置 ==========
# FastAPI 后端地址（前端请求用）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=ai_product_selection
